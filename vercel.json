{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag",  "value": "noindex" }
      ]
    },
    {
      "source": "/(admin|members|login|advisor|portfolio|memo|nda|ioi|code)(.*)",
      "headers": [
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/nda-template",        "destination": "/api/nda.js?op=template" },
    { "source": "/api/nda-upload",          "destination": "/api/nda.js?op=upload" },
    { "source": "/api/nda-status",          "destination": "/api/nda.js?op=status" },
    { "source": "/api/admin/:path*",  "destination": "/api/admin.js" },
    { "source": "/api/advisor/:path*", "destination": "/api/advisor.js" },
    { "source": "/memo",       "destination": "/_pages/memo.html" },
    { "source": "/nda",        "destination": "/_pages/nda.html" },
    { "source": "/ioi",        "destination": "/_pages/ioi.html" },
    { "source": "/main",       "destination": "/_pages/main.html" },
    { "source": "/portfolio",  "destination": "/_pages/portfolio.html" },
    { "source": "/advisor",    "destination": "/advisor.html" },
    { "source": "/advisor-login", "destination": "/login.html" }
  ]
}
